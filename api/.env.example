KYC_PORT=5050
PUBLIC_API_BASE=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ecodrive_db
DB_URL=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false
ADMIN_LOGIN_ID=
ADMIN_PASSWORD=


SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Ecodrive <no-reply@ecodrive.local>
SMTP_SECURE=false
INSTALLMENT_REMINDER_ENABLED=true
INSTALLMENT_REMINDER_LOOKAHEAD_DAYS=3
INSTALLMENT_REMINDER_SCAN_INTERVAL_MS=3600000
INSTALLMENT_REMINDER_BATCH_LIMIT=300

# Recommended SMS setup (built-in Semaphore relay, no separate SMS server)
SEMAPHORE_API_KEY=
SEMAPHORE_SENDERNAME=
SEMAPHORE_API_BASE=https://api.semaphore.co/api/v4
SEMAPHORE_REQUEST_TIMEOUT_MS=15000
SEMAPHORE_RELAY_TOKEN=

# Legacy/optional custom SMS webhook fallback
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=

AUTH_SESSION_TTL_MS=86400000
AUTH_SESSION_SECRET=
ALLOW_DEMO_OTP=false
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500
RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
OTP_SEND_RATE_LIMIT_MAX=6
OTP_VERIFY_RATE_LIMIT_MAX=10
